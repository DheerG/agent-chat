{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "AgentChat",
  "version": "0.1.0",
  "identifier": "com.agentchat.app",
  "build": {
    "beforeDevCommand": "pnpm --filter @agent-chat/client build",
    "frontendDist": "../../packages/client/dist"
  },
  "app": {
    "windows": [
      {
        "title": "AgentChat",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "wix": null,
      "nsis": null
    }
  }
}
