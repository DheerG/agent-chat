{
  "name": "agent-chat",
  "version": "0.0.0",
  "private": true,
  "bin": {
    "agent-chat": "./bin/cli.js"
  },
  "scripts": {
    "dev": "pnpm build && concurrently -n server,client -c blue,green \"node packages/server/dist/index.js\" \"pnpm --filter @agent-chat/client dev\"",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
